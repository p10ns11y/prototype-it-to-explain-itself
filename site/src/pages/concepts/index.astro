---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ConceptCard from '../../components/ConceptCard.astro';
import { CONCEPT_PAGES } from '../../lib/concept-meta';
---

<DocsLayout title="Concepts">
  <h1 class="text-3xl font-semibold mb-6">All Reference Pages</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {CONCEPT_PAGES.map((page) => (
      <ConceptCard slug={page.slug} title={page.title} description={page.description} />
    ))}
  </div>

  <div class="mt-8 text-sm text-zinc-600">
    These pages render directly from the project's canonical Markdown sources in <code>llm/</code> and <code>PROTOTYPE_ROADMAP.md</code>.
    The single-file <a href="/reflect-and-attempt-quizz.html" class="underline">Reflect and Attempt Quizz</a> provides active recall over the same concepts.
  </div>
</DocsLayout>
