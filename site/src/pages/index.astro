---
import DocsLayout from '../layouts/DocsLayout.astro';
import ConceptCard from '../components/ConceptCard.astro';
import { CONCEPT_PAGES } from '../lib/concept-meta';
---

<DocsLayout title="Prove it that you learned it Hub" description="Reference docs + active recall for Prototype It To Explain Itself">
  <div class="max-w-3xl">
    <h1 class="text-4xl font-semibold tracking-tight mb-3">Prove it that you learned it Hub</h1>
    <p class="text-lg text-zinc-600">
      High-quality reference pages for the core concepts + the interactive spaced-repetition tester.
    </p>

    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
      {CONCEPT_PAGES.map((page) => (
        <ConceptCard slug={page.slug} title={page.title} description={page.description} />
      ))}
    </div>

    <div class="mt-10 p-6 bg-white border border-zinc-200 rounded-3xl shadow-sm">
      <div class="font-medium mb-2 text-zinc-900">Active Recall Companion</div>
      <p class="text-sm text-zinc-600 mb-4">
        The single-file Reflect and Attempt Quizz uses spaced repetition over the same concepts.
        Use the hosted reference pages for deep reading, then switch to the tester for deliberate practice.
      </p>
      <a href="/reflect-and-attempt-quizz.html" class="inline-flex items-center gap-x-2 px-4 py-2 bg-white border border-zinc-300 text-zinc-800 hover:bg-zinc-100 hover:border-zinc-400 rounded-2xl text-sm font-medium">
        Open the Tester <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>
  </div>
</DocsLayout>
