---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  frontmatter?: { title?: string; description?: string };
}

const { title: propTitle, description: propDescription, frontmatter } = Astro.props;
const title = frontmatter?.title ?? propTitle ?? 'Concept';
const description = frontmatter?.description ?? propDescription;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} • Prototype It To Explain Itself</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  </head>
  <body class="bg-zinc-50 text-zinc-900">
    <div class="max-w-6xl mx-auto">
      <header class="flex items-center justify-between px-8 pt-6 pb-4 border-b border-zinc-200 bg-white">
        <div class="flex items-center gap-x-3">
          <a href="/" class="flex items-center gap-x-3">
            <div class="w-9 h-9 bg-zinc-900 rounded-2xl flex items-center justify-center">
              <i class="fa-solid fa-brain text-white"></i>
            </div>
            <div>
              <span class="font-semibold tracking-tight text-zinc-900">Prove it that you learned it Hub</span>
            </div>
          </a>
        </div>

        <nav class="flex items-center gap-x-4 text-sm">
          <a href="/reflect-and-attempt-quizz.html" class="text-zinc-600 hover:text-zinc-900 transition-colors">Tester</a>
          <a href="/concepts" class="text-zinc-600 hover:text-zinc-900 transition-colors">Concepts</a>
          <a href="https://github.com/p10ns11y/prototype-it-to-explain-itself" target="_blank" class="text-zinc-600 hover:text-zinc-900 transition-colors flex items-center gap-x-1">
            <i class="fa-brands fa-github"></i>
            <span>GitHub</span>
          </a>
        </nav>
      </header>

      <div class="px-8 py-8 prose">
        <slot />
      </div>

      <footer class="px-8 py-6 text-xs text-zinc-500 border-t border-zinc-200">
        Built in the spirit of the project: small, visual, self-explanatory, and interconnected.
        The single-file tester at the root remains fully portable.
      </footer>
    </div>
    <slot name="scripts" />
  </body>
</html>