{
  "name": "prototype-it-to-explain-itself-site",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=24.11.0",
    "pnpm": ">=11.5.3"
  },
  "scripts": {
    "predev": "mkdir -p public && cp ../reflect-and-attempt-quizz.html public/",
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "mkdir -p public && cp ../reflect-and-attempt-quizz.html public/",
    "build": "astro build",
    "preview": "astro preview",
    "pages:deploy": "pnpm build && wrangler pages deploy dist --project-name prototype-it-to-explain-itself",
    "pages:dev": "pnpm build && wrangler pages dev dist",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^6.4.6",
    "mermaid": "^11.15.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "wrangler": "^4.99.0"
  }
}
